{
  "name": "unitypackage-tools-workspace",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*", "fixtures"],
  "engines": { "node": ">=24" },
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:core": "bun run --filter unitypackage-core build",
    "build:web": "bun run --filter @unitypackage-tools/web build",
    "build:cli": "bun run build:web && node scripts/copy-web-assets.ts && bun run --filter unitypackage-tools build",
    "test": "bun run --filter '*' test",
    "test:core": "vitest run --project core",
    "test:cli": "vitest run --project cli",
    "test:web": "vitest run --project web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run lint && bun run typecheck && bun run build && bun run test && bun run smoke",
    "dev:web": "bun run --filter @unitypackage-tools/web dev",
    "clean": "node scripts/clean.ts",
    "smoke": "node scripts/smoke.ts",
    "pack:dry": "bun run build && npm pack --workspace unitypackage-core --dry-run && npm pack --workspace unitypackage-tools --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.19",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.4"
  }
}
