{
  "name": "unitypackage-tools",
  "version": "0.1.0",
  "description": "CLI tools for .unitypackage files — extract, pack, inspect, verify, web",
  "type": "module",
  "bin": {
    "unitypackage-tools": "dist/bin.js"
  },
  "files": ["dist", "assets/web", "README.md", "LICENSE"],
  "engines": { "node": ">=24" },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build && npm run lint && npm run test"
  },
  "dependencies": {
    "unitypackage-core": "workspace:*",
    "unitypackage-depgraph": "workspace:*"
  }
}
